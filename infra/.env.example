COMPOSE_PROJECT_NAME=coesite

POSTGRES_USER=coesite
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=coesite_dev
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Owner URL: migration/schema changes only. Do not use for app runtime.
OWNER_DATABASE_URL=postgresql://coesite:change-me-locally@localhost:5432/coesite_dev
DATABASE_URL=${OWNER_DATABASE_URL}

# Runtime URL: app INSERT/SELECT path only after the runtime role password is set.
RUNTIME_DATABASE_URL=postgresql://coesite_runtime:CHANGEME_RUNTIME_PASSWORD_FROM_KMS@localhost:5432/coesite_dev

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change-me-locally
