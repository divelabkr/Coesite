# Owner URL: Prisma migration/reset only. Application runtime must not use this role.
OWNER_DATABASE_URL=postgresql://coesite:change-me-locally@127.0.0.1:5432/coesite_dev
DATABASE_URL=${OWNER_DATABASE_URL}

# Phase 1 전에는 DATABASE_URL=$OWNER_DATABASE_URL 별칭을 권장한다.
# Runtime URL: app INSERT/SELECT path. Phase 1 must wire Prisma Client to this role.
# 컨테이너 외부 실행: postgresql://...@127.0.0.1:5432/...
# 컨테이너 내부 실행 (Phase 3+): postgresql://...@postgres:5432/...
RUNTIME_DATABASE_URL=postgresql://coesite_runtime:CHANGEME_RUNTIME_PASSWORD_FROM_KMS@127.0.0.1:5432/coesite_dev
REDIS_URL=redis://:change-me-locally@127.0.0.1:6379
JWT_SECRET=__REPLACE_WITH_RANDOM_32+_BYTES_FROM_KMS__
JWT_EXPIRES_IN=15m
NODE_ENV=development
PORT=3000
